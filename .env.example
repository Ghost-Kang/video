# ============================================================
# OpenRHTV 配置文件
# 复制为 .env 并填入实际的 key
# ============================================================

# -------- LLM --------
# Provider toggle: "doubao" (Phase 1 default, 境内, PIPL §38 不触发)
#                  "gemini" (fallback / A-B compare tool)
# 切换后无需改代码,仅重启 backend
LLM_PROVIDER=doubao

# Doubao (火山方舟 ARK, OpenAI 兼容端点)
# 获取地址: https://console.volcengine.com/ark
#   1. 创建推理接入点 → 选 doubao-seed-2-0-pro → 拿 endpoint id (ep-XXXX) 或直接用模型名
#   2. API Key 管理 → 签发 ARK_API_KEY
ARK_API_KEY=your_ark_key_here
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-seed-2-0-pro

# Google Gemini API key (fallback provider; 同时被图片生成的 google provider 复用)
# 获取地址: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_key_here
# LLM_MODEL: 仅当 LLM_PROVIDER=gemini 时使用;LLM_PROVIDER=doubao 时改读 DOUBAO_MODEL
LLM_MODEL=gemini-3-flash-preview

# -------- 图片生成 --------
# 默认 provider，用户在节点详情面板可按节点切换（"apimart" | "google"）
# Phase 1 合规默认 apimart (privacy_v0.md §4.3) — 用户主动切到 google = 二次同意触发境外
IMAGE_GEN_PROVIDER=apimart

# Apimart（OpenAI 兼容格式）
IMAGE_GEN_API_KEY=your_key_here
IMAGE_GEN_BASE_URL=https://api.apimart.ai
IMAGE_GEN_MODEL=gpt-image-2

# Google Gemini（复用上方 GOOGLE_API_KEY，无需额外配置）
IMAGE_GEN_GOOGLE_MODEL=gemini-3.1-flash-image-preview

# -------- 视频生成 --------
VIDEO_GEN_API_KEY=your_key_here
VIDEO_GEN_BASE_URL=
# Seedance 2.0 (Volcengine Ark)
ARK_API_KEY=your_key_here
ARK_VIDEO_MODEL=doubao-seedance-2-0-260128

# -------- TTS 语音合成 --------
TTS_API_KEY=your_key_here
TTS_BASE_URL=

# -------- S3 --------
S3_AK=your_key_here
S3_SK=your_key_here
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_BASE_URL=

# -------- ASR 语音识别 --------
ASR_API_KEY=your_key_here
ASR_BASE_URL=

# -------- Cascade analysis upstream (P5-3 / W4D5) --------
# CASCADE_UPSTREAM modes:
#   fixture       — local synthetic data (dev/test, no network)
#   mediakit      — MediaKit storyline + ARK overlay (RISK: storyline /analyze-video-storyline
#                   has been observed to hang indefinitely on real Douyin URLs as of 2026-05-27)
#   toprador      — internal toprador HTTP endpoint (requires TOPRADOR_ENDPOINT)
#   doubao_direct — single-shot ARK Doubao seed-1.6 vision call against the direct
#                   .mp4 URL (RECOMMENDED for real Douyin URLs while MediaKit storyline
#                   is degraded; ~¥0.50/call, 30-90s typical)
CASCADE_UPSTREAM=doubao_direct
# 火山 MediaKit Bearer token, used by CASCADE_UPSTREAM=mediakit and by the
# doubao_direct ARK auth header (Bearer {ARK_API_KEY}/{VOLC_MEDIAKIT_AK}).
VOLC_MEDIAKIT_AK=your_mediakit_ak_here

# -------- URL resolver mode (W4D5) --------
# MediaKit needs a direct .mp4 URL, but users paste page URLs
# (douyin.com/video/<id>). The resolver turns one into the other.
#   passthrough   — default; returns input as-is. MediaKit will fail
#                   on a real Douyin page URL.
#   douyin_share  — scrapes iesdouyin.com/share/video/<id>/ SSR HTML
#                   for play_addr (no cookies / yt-dlp needed). Required
#                   for live Douyin URLs.
#   toprador_http / toprador_pyimport — placeholders, raise S8 today.
# Set this together with CASCADE_UPSTREAM=mediakit OR doubao_direct for real Douyin URLs.
TOPRADOR_RESOLVER_MODE=douyin_share
